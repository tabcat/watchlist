{
  "name": "@tabcat/newline-set",
  "version": "1.0.0",
  "description": "reads a newline-delimited file into a live Set<string> that stays in sync as the file changes",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "./dist/src"
  ],
  "keywords": [],
  "author": "tabcat",
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "pnpm install && pnpm build",
    "lint": "dprint check",
    "format": "dprint fmt",
    "build": "tsc",
    "test": "vitest --dir test --config vitest.config.ts --run",
    "test:watch": "vitest --dir test --config vitest.config.ts",
    "api-docs": "typedoc src",
    "bench": "vitest bench --dir benchmarks --config vitest.config.ts --run",
    "ci": "pnpm build && pnpm lint && pnpm test"
  },
  "lint-staged": {
    "*/**": "pnpm run format"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dprint": "^0.52.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@libp2p/logger": "^6.2.2",
    "chokidar": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild"
    ]
  }
}